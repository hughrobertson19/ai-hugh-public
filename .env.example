# =====================================================================
# AI Hugh — environment variables
# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real credentials.
# =====================================================================

# --- API keys ---
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
NOTION_API_KEY=your-notion-key

# --- Notion database IDs ---
NOTION_COMPANIES_DB_ID=your-db-id
NOTION_CONTACTS_DB_ID=your-db-id
NOTION_TASKS_DB_ID=your-db-id
NOTION_MEETINGS_DB_ID=your-db-id
NOTION_OBJECTIONS_DB_ID=your-db-id
NOTION_PROOF_POINTS_DB_ID=your-db-id
NOTION_PRODUCT_FEEDBACK_DB_ID=your-db-id
NOTION_DEALS_DB_ID=your-db-id
NOTION_COMPETITIVE_INTEL_DB_ID=your-db-id
NOTION_SPRINTS_DB_ID=your-db-id

# --- Email (SMTP, e.g. Office 365 / Gmail / SES) ---
SMTP_SERVER=smtp.your-provider.example
OUTLOOK_APP_PASSWORD=your-app-password
SMTP_FROM=your-email@company.com
SALESFORCE_BCC=your-sf-bcc@salesforce.com

# --- Market intel models (optional overrides) ---
MI_SCORING_MODEL=gpt-4o-mini
MI_PODCAST_MODEL=gpt-4o-mini
